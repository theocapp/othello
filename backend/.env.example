# Core runtime
GROQ_API_KEY=
ANTHROPIC_API_KEY=
NEWS_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# API / frontend integration
OTHELLO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
OTHELLO_ADMIN_API_KEY=

# Runtime flags
OTHELLO_INTERNAL_SCHEDULER=false
OTHELLO_WORKER_BOOTSTRAP_MODE=ingest
OTHELLO_WORKER_ENABLE_INGESTION=true
OTHELLO_WORKER_ENABLE_TRANSLATIONS=false
OTHELLO_WORKER_ENABLE_ANALYTICS=false

# Optional feature flags
OTHELLO_ENABLE_VECTOR_SEARCH=false
OTHELLO_ENABLE_CHROMA_INGEST=false
OTHELLO_ENABLE_LIVE_FETCH=false
OTHELLO_ENABLE_LLM_RESPONSES=false
OTHELLO_ENABLE_TRANSLATION=true
