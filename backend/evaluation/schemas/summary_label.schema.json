{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SummaryLabel",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "event_id",
    "overall_quality",
    "label_decision",
    "annotator_id",
    "annotated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "kind": { "const": "summary" },
    "event_id": { "type": "string", "minLength": 1 },
    "overall_quality": { "type": "integer", "minimum": 1, "maximum": 5 },
    "label_decision": {
      "type": "string",
      "enum": ["faithful", "missing_critical_facts", "hallucinated", "mixed"]
    },
    "annotator_id": { "type": "string", "minLength": 1 },
    "annotated_at": { "type": "string", "format": "date-time" },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
