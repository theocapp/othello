{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClusteringLabel",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "event_id",
    "observation_key",
    "label_decision",
    "annotator_id",
    "annotated_at"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "kind": { "const": "clustering" },
    "event_id": { "type": "string", "minLength": 1 },
    "observation_key": { "type": "string", "minLength": 1 },
    "label_decision": {
      "type": "string",
      "enum": ["correct_cluster", "false_merge", "false_split", "duplicate", "unsure"]
    },
    "annotator_id": { "type": "string", "minLength": 1 },
    "annotated_at": { "type": "string", "format": "date-time" },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
